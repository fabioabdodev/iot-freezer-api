generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TemperatureLog {
  id          String   @id @default(uuid())
  deviceId    String
  temperature Float
  createdAt   DateTime @default(now())

  @@index([deviceId, createdAt])
}

model Device {
  id       String    @id
  clientId String?
  client   Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  name     String?
  location String?
  lastSeen DateTime?

  isOffline    Boolean   @default(false)
  offlineSince DateTime?
  lastAlertAt  DateTime?

  // configurable temperature boundaries for each device
  minTemperature Float? // null => no lower limit
  maxTemperature Float? // null => no upper limit

  @@index([clientId])
}

model Client {
  id        String   @id
  name      String
  createdAt DateTime @default(now())
  devices   Device[]
}
